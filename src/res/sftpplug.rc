IDD_WEBDAV DIALOGEX 0, 0, 286, 320
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_NOPARENTNOTIFY
CAPTION "Connect to SFTP Server"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "&Connect to: (server/path or server:port/path)", IDC_STATIC,5,5,166,8
    CONTROL         "Auto",IDC_PROTOAUTO,"Button",BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,186,5,27,10
    CONTROL         "IPv4",IDC_PROTOV4,"Button",BS_AUTORADIOBUTTON,218,5,31,10
    CONTROL         "IPv6",IDC_PROTOV6,"Button",BS_AUTORADIOBUTTON,250,5,31,10
    EDITTEXT        IDC_CONNECTTO,5,15,276,12,ES_AUTOHSCROLL
    LTEXT           "&User name:",IDC_STATIC,5,31,266,8
    EDITTEXT        IDC_USERNAME,5,42,276,12,ES_AUTOHSCROLL
    LTEXT           "&Password:",IDC_PASSLABEL,5,58,61,8
    PUSHBUTTON      "?",IDC_PASSWORDHELP,78,57,12,10
    CONTROL         "Use SSH agent (Pageant)",IDC_USEAGENT,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,90,58,150,8
    PUSHBUTTON      "Change password...",IDC_EDITPASS,5,71,276,14,NOT WS_VISIBLE
    EDITTEXT        IDC_PASSWORD,5,68,276,12,ES_PASSWORD | ES_AUTOHSCROLL
    CONTROL         "Protect password with password manager (TC>=7.5)",IDC_CRYPTPASS,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,82, 276,10
    GROUPBOX        "Client certificate for &authentication:",IDC_STATIC,5,92,276,60
    LTEXT           "Public key file (*.pub):",IDC_STATICPUB,10,103,240,8
    EDITTEXT        IDC_PUBKEY,10,112,249,12,ES_AUTOHSCROLL
    PUSHBUTTON      ">>",IDC_LOADPUBKEY,260,112,16,12
    LTEXT           "Private key file (*.pem;*.ppk):",IDC_STATICPEM,10,126,253,8
    EDITTEXT        IDC_PRIVKEY,10,136,249,12,ES_AUTOHSCROLL
    PUSHBUTTON      ">>",IDC_LOADPRIVKEY,260,136,16,12
    PUSHBUTTON      "?",IDC_CERTHELP,246,100,12,10
    PUSHBUTTON      "?",IDC_CERTHELPPRIV,246,124,12,10
    CONTROL         "Compress with &ZLIB (may fail on some servers)",IDC_COMPRESS,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,152,276,10
    CONTROL         "Log full directory listings (&debug)",IDC_DETAILED_LOG,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,162,276,10
    CONTROL         "Use shell transfer (blocked hosts)",IDC_SHELLTRANSFER,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,172,146,10
    CONTROL         "Use SCP for data transfers (faster!)",IDC_SCP_DATA,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,182,146,10
    CONTROL         "Use SCP for everything (no SFTP)",IDC_SCP_ALL,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,192,146,10
    LTEXT           "Transfer:",IDC_STATIC,165,175,34,8
    COMBOBOX        IDC_TRANSFERMODE,199,173,82,46,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "System:",IDC_SYSTEMLABEL,165,187,34,8
    COMBOBOX        IDC_SYSTEM,199,185,82,30,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CONTROL         "Encoding (codepage) of file names:",IDC_CODEPAGELABEL,"Static",SS_SIMPLE | WS_GROUP,5,202,140,8
    COMBOBOX        IDC_UTF8,199,199,82,127,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "?",IDC_UTF8HELP,185,200,12,10
    GROUPBOX        " User &rights of newly created files/directories: ",IDC_PERMISSIONS_GROUP,5,212,266,26,WS_GROUP
    CONTROL         "New files (Upload):",IDC_FILEMOD_LABEL,"Static",SS_SIMPLE | WS_GROUP,13,224,70,8
    EDITTEXT        IDC_FILEMOD,87,222,28,12,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "New folders:",IDC_DIRMOD_LABEL,160,224,47,8
    EDITTEXT        IDC_DIRMOD,210,222,28,12,ES_AUTOHSCROLL | ES_NUMBER
    GROUPBOX        " LAN Pair Session: ",IDC_LANPAIR_GROUP,5,212,266,26,WS_GROUP | NOT WS_VISIBLE
    LTEXT           "Session timeout (min):",IDC_LAN_TIMEOUT_LABEL,13,224,80,8,NOT WS_VISIBLE
    EDITTEXT        IDC_LAN_TIMEOUT,95,222,30,12,ES_AUTOHSCROLL | ES_NUMBER | NOT WS_VISIBLE
    LTEXT           "(0=no limit)",IDC_LAN_TIMEOUT_HINT,130,224,50,8,NOT WS_VISIBLE
    LTEXT           "Session:",IDC_STATIC,5,241,30,8
    COMBOBOX        IDC_SESSIONCOMBO,38,239,210,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Shell...",IDC_PHPSHELL,251,239,30,14
    LTEXT           "Jump host:",IDC_STATIC,5,257,42,8
    CONTROL         "Use &jump host",IDC_JUMP_ENABLE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,49,257,104,8
    PUSHBUTTON      "Jump...",IDC_JUMP_BUTTON,195,255,40,14
    LTEXT           "Proxy settings:",IDC_STATIC,5,273,266,8
    COMBOBOX        IDC_PROXYCOMBO,5,283,254,30,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      ">>",IDC_PROXYBUTTON,261,282,20,14
    PUSHBUTTON      "Delete last proxy",IDC_DELETELAST,5,301,98,14
    PUSHBUTTON      "Import...",IDC_IMPORTSESSIONS,105,301,58,14
    PUSHBUTTON      "Help",IDC_PLUGINHELP,165,301,28,14
    DEFPUSHBUTTON   "OK",IDOK,197,301,28,14
    PUSHBUTTON      "Cancel",IDCANCEL,231,301,50,14
END

