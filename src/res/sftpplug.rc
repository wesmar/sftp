/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_WEBDAV DIALOGEX 0, 0, 286, 320
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_NOPARENTNOTIFY
CAPTION "Conectar al servidor SFTP"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "&Conectar a: (servidor/ruta o servidor:puerto/ruta)", IDC_STATIC,5,5,166,8
    CONTROL         "Auto",IDC_PROTOAUTO,"Button",BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,186,5,27,10
    CONTROL         "IPv4",IDC_PROTOV4,"Button",BS_AUTORADIOBUTTON,218,5,31,10
    CONTROL         "IPv6",IDC_PROTOV6,"Button",BS_AUTORADIOBUTTON,250,5,31,10
    EDITTEXT        IDC_CONNECTTO,5,15,276,12,ES_AUTOHSCROLL
    LTEXT           "&Usuario:",IDC_STATIC,5,31,266,8
    EDITTEXT        IDC_USERNAME,5,42,276,12,ES_AUTOHSCROLL
    LTEXT           "&Contraseña:",IDC_PASSLABEL,5,58,61,8
    PUSHBUTTON      "?",IDC_PASSWORDHELP,78,57,12,10
    CONTROL         "Usar agente SSH (Pageant)",IDC_USEAGENT,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,90,58,150,8
    PUSHBUTTON      "Cambiar contraseña...",IDC_EDITPASS,5,71,276,14,NOT WS_VISIBLE
    EDITTEXT        IDC_PASSWORD,5,68,276,12,ES_PASSWORD | ES_AUTOHSCROLL
    CONTROL         "Proteger contraseña con gestor (TC>=7.5)",IDC_CRYPTPASS,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,82, 276,10
    GROUPBOX        "Certificado cliente para &autenticación:",IDC_STATIC,5,92,276,60
    LTEXT           "Archivo de clave pública (*.pub):",IDC_STATICPUB,10,103,240,8
    EDITTEXT        IDC_PUBKEY,10,112,249,12,ES_AUTOHSCROLL
    PUSHBUTTON      ">>",IDC_LOADPUBKEY,260,112,16,12
    LTEXT           "Archivo de clave privada (*.pem;*.ppk):",IDC_STATICPEM,10,126,253,8
    EDITTEXT        IDC_PRIVKEY,10,136,249,12,ES_AUTOHSCROLL
    PUSHBUTTON      ">>",IDC_LOADPRIVKEY,260,136,16,12
    PUSHBUTTON      "?",IDC_CERTHELP,246,100,12,10
    PUSHBUTTON      "?",IDC_CERTHELPPRIV,246,124,12,10
    CONTROL         "Comprimir con &ZLIB (puede fallar)",IDC_COMPRESS,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,152,276,10
    CONTROL         "Listados completos al log (&depuración)",IDC_DETAILED_LOG,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,162,276,10
    CONTROL         "Transferencia shell (hosts bloqueados)",IDC_SHELLTRANSFER,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,172,146,10
    CONTROL         "Usar SCP para transferencias (más rápido)",IDC_SCP_DATA,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,182,146,10
    CONTROL         "Usar SCP para todo (sin SFTP)",IDC_SCP_ALL,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,192,146,10
    LTEXT           "Transfer:",IDC_STATIC,165,175,34,8
    COMBOBOX        IDC_TRANSFERMODE,199,173,82,46,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "System:",IDC_SYSTEMLABEL,165,187,34,8
    COMBOBOX        IDC_SYSTEM,199,185,82,30,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CONTROL         "Codificación (página de códigos) de nombres:",IDC_CODEPAGELABEL,"Static",SS_SIMPLE | WS_GROUP,5,202,140,8
    COMBOBOX        IDC_UTF8,199,199,82,127,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "?",IDC_UTF8HELP,185,200,12,10
    GROUPBOX        " &Permisos para archivos/carpetas nuevas: ",IDC_PERMISSIONS_GROUP,5,212,266,26,WS_GROUP
    CONTROL         "Nuevos archivos (subida):",IDC_FILEMOD_LABEL,"Static",SS_SIMPLE | WS_GROUP,13,224,70,8
    EDITTEXT        IDC_FILEMOD,87,222,28,12,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Nuevas carpetas:",IDC_DIRMOD_LABEL,160,224,47,8
    EDITTEXT        IDC_DIRMOD,210,222,28,12,ES_AUTOHSCROLL | ES_NUMBER
    GROUPBOX        " LAN Pair Session: ",IDC_LANPAIR_GROUP,5,212,266,26,WS_GROUP | NOT WS_VISIBLE
    LTEXT           "Session timeout (min):",IDC_LAN_TIMEOUT_LABEL,13,224,80,8,NOT WS_VISIBLE
    EDITTEXT        IDC_LAN_TIMEOUT,95,222,30,12,ES_AUTOHSCROLL | ES_NUMBER | NOT WS_VISIBLE
    LTEXT           "(0=no limit)",IDC_LAN_TIMEOUT_HINT,130,224,50,8,NOT WS_VISIBLE
    LTEXT           "Sesión:",IDC_STATIC,5,241,30,8
    COMBOBOX        IDC_SESSIONCOMBO,38,239,210,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Shell...",IDC_PHPSHELL,251,239,30,14
    LTEXT           "Jump host:",IDC_STATIC,5,257,42,8
    CONTROL         "Usar &jump host",IDC_JUMP_ENABLE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,49,257,104,8
    PUSHBUTTON      "Jump...",IDC_JUMP_BUTTON,195,255,40,14
    LTEXT           "Configuración de proxy:",IDC_STATIC,5,273,266,8
    COMBOBOX        IDC_PROXYCOMBO,5,283,254,30,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      ">>",IDC_PROXYBUTTON,261,282,20,14
    PUSHBUTTON      "Eliminar proxy",IDC_DELETELAST,5,301,98,14
    PUSHBUTTON      "Import...",IDC_IMPORTSESSIONS,105,301,58,14
    PUSHBUTTON      "Ayuda",IDC_PLUGINHELP,165,301,28,14
    DEFPUSHBUTTON   "OK",IDOK,197,301,28,14
    PUSHBUTTON      "Cancelar",IDCANCEL,231,301,50,14
END

IDD_PROPERTIES DIALOGEX DISCARDABLE  0, 0, 249, 214
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Propiedades"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,123,193,50,14
    PUSHBUTTON      "Cancelar",IDCANCEL,192,193,50,14
    GROUPBOX        "Propiedades del archivo",IDC_STATIC,7,7,235,93
    LTEXT           "Name:",IDC_STATIC,16,20,22,8
    LTEXT           "Propietario:",IDC_STATIC,16,33,24,8
    LTEXT           "Grupo:",IDC_STATIC,16,46,22,8
    LTEXT           "Permisos:",IDC_STATIC,16,59,40,8
    LTEXT           "Tamaño:",IDC_STATIC,16,72,16,8
    LTEXT           "Última modificación:",IDC_STATIC,16,85,44,8
    EDITTEXT        IDC_PROP_NAME,72,20,164,12,ES_AUTOHSCROLL | ES_READONLY | 
                    NOT WS_BORDER
    EDITTEXT        IDC_PROP_OWNER,72,33,164,12,ES_AUTOHSCROLL | ES_READONLY | 
                    NOT WS_BORDER
    EDITTEXT        IDC_PROP_GROUP,72,46,164,12,ES_AUTOHSCROLL | ES_READONLY | 
                    NOT WS_BORDER
    EDITTEXT        IDC_PROP_PERMISSIONS,72,59,164,12,ES_AUTOHSCROLL | 
                    ES_READONLY | NOT WS_BORDER
    EDITTEXT        IDC_PROP_SIZE,72,72,164,12,ES_AUTOHSCROLL | ES_READONLY | 
                    NOT WS_BORDER
    EDITTEXT        IDC_PROP_MODIFIED,72,85,164,12,ES_AUTOHSCROLL | 
                    ES_READONLY | NOT WS_BORDER
    GROUPBOX        " Respuesta STAT sin procesar",IDC_STATIC,7,103,235,88
    EDITTEXT        IDC_PROP_RAWSTAT,15,113,220,73,ES_MULTILINE | 
                    ES_AUTOVSCROLL | ES_AUTOHSCROLL | ES_READONLY | NOT 
                    WS_BORDER
END

IDD_PROXY DIALOGEX DISCARDABLE  0, 0, 280, 119
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Configuración de proxy"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    CONTROL         "&Sin proxy",IDC_NOPROXY,"Button",BS_AUTORADIOBUTTON,12,
                    19,45,10
    CONTROL         "HTTP CONNECT",IDC_OTHERPROXY,"Button",
                    BS_AUTORADIOBUTTON,67,19,67,10
    CONTROL         "SOCKS 4/4a",IDC_SOCKS4APROXY,"Button",
                    BS_AUTORADIOBUTTON,144,19,53,10
    CONTROL         "SOCKS 5",IDC_SOCKS5PROXY,"Button",BS_AUTORADIOBUTTON,
                    200,19,44,10
    CONTROL         "Servidor proxy:",IDC_STATIC,"Static",SS_SIMPLE | WS_GROUP,
                    12,36,43,8
    EDITTEXT        IDC_PROXYSERVER,69,34,198,12,ES_AUTOHSCROLL
    CONTROL         "Usuario proxy:",IDC_STATIC,"Static",SS_SIMPLE | 
                    WS_GROUP,12,52,54,8
    EDITTEXT        IDC_PROXYUSERNAME,69,50,198,12,ES_AUTOHSCROLL
    CONTROL         "Contraseña proxy:",IDC_STATIC,"Static",SS_SIMPLE | 
                    WS_GROUP,12,67,55,8
    EDITTEXT        IDC_PROXYPASSWORD,69,66,198,12,ES_PASSWORD | 
                    ES_AUTOHSCROLL
    PUSHBUTTON      "?",IDC_PROXYHELP,256,19,12,10
    GROUPBOX        "Proxy settings",IDC_STATIC,7,7,266,88
    PUSHBUTTON      "Cambiar contraseña...",IDC_EDITPASS,69,66,198,14,NOT 
                    WS_VISIBLE
    CONTROL         "Proteger contraseña con gestor (TC>=7.5)",
                    IDC_CRYPTPASS,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,12,
                    81,258,10
    DEFPUSHBUTTON   "OK",IDOK,167,98,50,14
    PUSHBUTTON      "Cancelar",IDCANCEL,223,98,50,14
END


