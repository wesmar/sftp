    LTEXT           "Передача:",IDC_STATIC,165,175,34,8
    COMBOBOX        IDC_TRANSFERMODE,199,173,82,46,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Система:",IDC_SYSTEMLABEL,165,187,34,8
