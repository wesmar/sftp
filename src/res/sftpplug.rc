IDD_WEBDAV DIALOGEX 0, 0, 315, 320
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_NOPARENTNOTIFY
CAPTION "Connect to SFTP Server"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "&Connect to: (server/path or server:port/path)",IDC_LABEL_CONNECTTO,5,5,207,8
    CONTROL         "Auto",IDC_PROTOAUTO,"Button",BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,215,5,27,10
    CONTROL         "IPv4",IDC_PROTOV4,"Button",BS_AUTORADIOBUTTON,247,5,31,10
    CONTROL         "IPv6",IDC_PROTOV6,"Button",BS_AUTORADIOBUTTON,279,5,31,10
    EDITTEXT        IDC_CONNECTTO,5,15,305,12,ES_AUTOHSCROLL
    LTEXT           "&User name:",IDC_LABEL_USERNAME,5,31,295,8
    EDITTEXT        IDC_USERNAME,5,42,305,12,ES_AUTOHSCROLL
    LTEXT           "&Password:",IDC_PASSLABEL,5,58,54,8
    PUSHBUTTON      "?",IDC_PASSWORDHELP,43,57,12,10
    CONTROL         "Use SSH agent (Pageant)",IDC_USEAGENT,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,170,58,135,8
    PUSHBUTTON      "Change password...",IDC_EDITPASS,5,71,305,14,NOT WS_VISIBLE
    EDITTEXT        IDC_PASSWORD,5,68,305,12,ES_PASSWORD | ES_AUTOHSCROLL
    CONTROL         "Protect password with password manager (TC>=7.5)",IDC_CRYPTPASS,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,82,305,10
    GROUPBOX        "Client certificate for &authentication:",IDC_LABEL_CERTGROUP,5,92,305,60
    LTEXT           "Public key file (*.pub):",IDC_STATICPUB,10,103,269,8
    EDITTEXT        IDC_PUBKEY,10,112,261,12,ES_AUTOHSCROLL
    PUSHBUTTON      "?",IDC_CERTHELP,275,112,12,12
    PUSHBUTTON      ">>",IDC_LOADPUBKEY,289,112,16,12
    LTEXT           "Private key file (*.pem;*.ppk):",IDC_STATICPEM,10,126,282,8
    EDITTEXT        IDC_PRIVKEY,10,136,261,12,ES_AUTOHSCROLL
    PUSHBUTTON      "?",IDC_CERTHELPPRIV,275,136,12,12
    PUSHBUTTON      ">>",IDC_LOADPRIVKEY,289,136,16,12
    CONTROL         "Compress with &ZLIB (may fail on some servers)",IDC_COMPRESS,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,152,305,10
    CONTROL         "Log full directory listings (&debug)",IDC_DETAILED_LOG,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,162,305,10
    CONTROL         "Use shell transfer (blocked hosts)",IDC_SHELLTRANSFER,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,172,192,10
    CONTROL         "Use SCP for data transfers (faster!)",IDC_SCP_DATA,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,182,191,10
    CONTROL         "Use SCP for everything (no SFTP)",IDC_SCP_ALL,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,192,167,10
    LTEXT           "Transfer:",IDC_LABEL_TRANSFER,200,176,40,8
    COMBOBOX        IDC_TRANSFERMODE,234,173,76,46,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "System:",IDC_SYSTEMLABEL,200,187,40,8
    COMBOBOX        IDC_SYSTEM,234,185,76,30,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CONTROL         "Encoding (codepage) of file names:",IDC_CODEPAGELABEL,
                    "Static",SS_SIMPLE | WS_GROUP,5,202,169,8
    COMBOBOX        IDC_UTF8,234,199,76,127,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "?",IDC_UTF8HELP,218,200,12,10
    GROUPBOX        " User &rights of newly created files/directories: ",IDC_PERMISSIONS_GROUP,5,212,295,26,WS_GROUP
    CONTROL         "New files (Upload):",IDC_FILEMOD_LABEL,"Static",SS_SIMPLE | WS_GROUP,13,224,70,8
    EDITTEXT        IDC_FILEMOD,87,222,28,12,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "New folders:",IDC_DIRMOD_LABEL,160,224,47,8
    EDITTEXT        IDC_DIRMOD,210,222,28,12,ES_AUTOHSCROLL | ES_NUMBER
    GROUPBOX        " LAN Pair Session: ",IDC_LANPAIR_GROUP,5,212,295,26,NOT WS_VISIBLE | WS_GROUP
    LTEXT           "Session timeout (min):",IDC_LAN_TIMEOUT_LABEL,13,224,80,8,NOT WS_VISIBLE
    EDITTEXT        IDC_LAN_TIMEOUT,95,222,30,12,ES_AUTOHSCROLL | ES_NUMBER | NOT WS_VISIBLE
    LTEXT           "(0=no limit)",IDC_LAN_TIMEOUT_HINT,130,224,50,8,NOT WS_VISIBLE
    LTEXT           "Session:",IDC_LABEL_SESSION,5,241,30,8
    COMBOBOX        IDC_SESSIONCOMBO,38,239,227,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Shell...",IDC_PHPSHELL,270,238,40,14
    LTEXT           "Jump host:",IDC_LABEL_JUMPHOST_GRP,5,257,42,8
    CONTROL         "Use &jump host",IDC_JUMP_ENABLE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,49,257,104,8
    PUSHBUTTON      "Jump...",IDC_JUMP_BUTTON,224,255,40,14
    CONTROL         "TAR",IDC_PHP_TAR,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,242,224,60,8
    LTEXT           "Proxy settings:",IDC_LABEL_PROXY_SETTINGS,5,273,295,8
    COMBOBOX        IDC_PROXYCOMBO,5,283,282,30,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      ">>",IDC_PROXYBUTTON,290,282,20,14
    PUSHBUTTON      "Delete last proxy",IDC_DELETELAST,5,301,105,14
    PUSHBUTTON      "Import...",IDC_IMPORTSESSIONS,113,301,70,14
    PUSHBUTTON      "Help",IDC_PLUGINHELP,186,301,40,14
    DEFPUSHBUTTON   "OK",IDOK,229,301,26,14
    PUSHBUTTON      "Cancel",IDCANCEL,258,301,50,14
END

