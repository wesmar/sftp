/////////////////////////////////////////////////////////////////////////////
// Jump Host (ProxyJump) settings dialog — language neutral
/////////////////////////////////////////////////////////////////////////////

IDD_JUMPHOST DIALOGEX DISCARDABLE 0, 0, 300, 185
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "SSH Jump Host (ProxyJump) Settings"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    GROUPBOX        "Jump host connection",IDC_STATIC,5,5,290,170
    CONTROL         "&Use jump host (ProxyJump)",IDC_JUMP_ENABLE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,12,17,180,10

    LTEXT           "Jump host:",IDC_STATIC,12,33,50,8
    EDITTEXT        IDC_JUMP_HOST,65,31,155,12,ES_AUTOHSCROLL
    LTEXT           "Port:",IDC_STATIC,225,33,18,8
    EDITTEXT        IDC_JUMP_PORT,245,31,43,12,ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "User name:",IDC_STATIC,12,50,50,8
    EDITTEXT        IDC_JUMP_USER,65,48,223,12,ES_AUTOHSCROLL

    LTEXT           "&Password:",IDC_STATIC,12,67,50,8
    EDITTEXT        IDC_JUMP_PASSWORD,65,65,223,12,ES_PASSWORD | ES_AUTOHSCROLL
    CONTROL         "Protect password with password manager (TC>=7.5)",IDC_JUMP_CRYPTPASS,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,12,80,276,10
    PUSHBUTTON      "Change password...",IDC_JUMP_EDITPASS,65,65,223,14,NOT WS_VISIBLE

    LTEXT           "Public key file (*.pub):",IDC_STATIC,12,95,120,8
    EDITTEXT        IDC_JUMP_PUBKEY,12,105,260,12,ES_AUTOHSCROLL
    PUSHBUTTON      ">>",IDC_JUMP_LOADPUBKEY,274,105,16,12

    LTEXT           "Private key file (*.pem;*.ppk):",IDC_STATIC,12,121,180,8
    EDITTEXT        IDC_JUMP_PRIVKEY,12,131,260,12,ES_AUTOHSCROLL
    PUSHBUTTON      ">>",IDC_JUMP_LOADPRIVKEY,274,131,16,12

    CONTROL         "Use SSH &agent (Pageant) for jump host auth",IDC_JUMP_USEAGENT,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,12,149,276,10

    DEFPUSHBUTTON   "OK",IDOK,186,163,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,242,163,50,14
END









